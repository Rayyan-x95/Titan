# Titan PWA - Local Environment Configuration

# The public base URL of the deployment (used for canonical URLs, sitemaps, etc.)
VITE_PUBLIC_URL=https://titan.ninety5.in

# WebRTC signaling relay server for direct peer-to-peer sync
VITE_SIGNALING_SERVER=wss://signaling.yjs.dev

# Custom WebRTC pairing salt for deriving room IDs
VITE_PAIRING_SALT=-titan-pairing-salt-2026

# Custom WebRTC ICE / STUN / TURN servers in JSON array format
VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"}]

# Security PIN hashing salt (Advanced PBKDF2)
VITE_PIN_SALT=titan-pin-salt-v1

# PBKDF2 iterations for direct WebRTC encryption keys
VITE_SYNC_PBKDF2_ITERATIONS=100000

# Development server port (Vite)
PORT=8000
